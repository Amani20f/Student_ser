                {
                    "name": "Preview Grade Import",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "file",
                                    "type": "file",
                                    "src": [],
                                    "description": "Excel file (.xlsx) containing grades to import"
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{baseUrl}}/staff/grades/import/preview",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "staff",
                                "grades",
                                "import",
                                "preview"
                            ]
                        },
                        "description": "Uploads an Excel file and returns detected column headers for mapping. Accessible only by roles: grade_control, admin."
                    },
                    "response": [
                        {
                            "name": "Success",
                            "originalRequest": {
                                "method": "POST",
                                "header": [
                                    {
                                        "key": "Accept",
                                        "value": "application/json",
                                        "type": "text"
                                    }
                                ],
                                "body": {
                                    "mode": "formdata",
                                    "formdata": [
                                        {
                                            "key": "file",
                                            "type": "file",
                                            "src": []
                                        }
                                    ]
                                },
                                "url": {
                                    "raw": "{{baseUrl}}/staff/grades/import/preview",
                                    "host": [
                                        "{{baseUrl}}"
                                    ],
                                    "path": [
                                        "staff",
                                        "grades",
                                        "import",
                                        "preview"
                                    ]
                                }
                            },
                            "status": "OK",
                            "code": 200,
                            "_postman_previewlanguage": "json",
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json"
                                }
                            ],
                            "body": "{\n    \"headers\": [\n        \"student_number\",\n        \"course_code\",\n        \"semester\",\n        \"first\",\n        \"final\"\n    ],\n    \"temp_path\": \"temp/imports/abc123.xlsx\"\n}"
                        }
                    ]
                },
                {
                    "name": "Store Grade Import",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json",
                                "type": "text"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json",
                                "type": "text"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"temp_path\": \"temp/imports/example.xlsx\",\n    \"mapping\": {\n        \"student_number\": 0,\n        \"course_code\": 1,\n        \"semester_id\": 2,\n        \"first\": 3,\n        \"second\": 4,\n        \"midterm\": 5,\n        \"final\": 6\n    }\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/staff/grades/import/store",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "staff",
                                "grades",
                                "import",
                                "store"
                            ]
                        },
                        "description": "Processes the previously uploaded Excel file and saves grades into the database using column index mapping. Accessible only by roles: grade_control, admin."
                    },
                    "response": [
                        {
                            "name": "Success",
                            "originalRequest": {
                                "method": "POST",
                                "header": [
                                    {
                                        "key": "Accept",
                                        "value": "application/json",
                                        "type": "text"
                                    },
                                    {
                                        "key": "Content-Type",
                                        "value": "application/json",
                                        "type": "text"
                                    }
                                ],
                                "body": {
                                    "mode": "raw",
                                    "raw": "{\n    \"temp_path\": \"temp/imports/example.xlsx\",\n    \"mapping\": {\n        \"student_number\": 0,\n        \"course_code\": 1,\n        \"semester_id\": 2,\n        \"first\": 3,\n        \"second\": 4,\n        \"midterm\": 5,\n        \"final\": 6\n    }\n}",
                                    "options": {
                                        "raw": {
                                            "language": "json"
                                        }
                                    }
                                },
                                "url": {
                                    "raw": "{{baseUrl}}/staff/grades/import/store",
                                    "host": [
                                        "{{baseUrl}}"
                                    ],
                                    "path": [
                                        "staff",
                                        "grades",
                                        "import",
                                        "store"
                                    ]
                                }
                            },
                            "status": "OK",
                            "code": 200,
                            "_postman_previewlanguage": "json",
                            "header": [
                                {
                                    "key": "Content-Type",
                                    "value": "application/json"
                                }
                            ],
                            "body": "{\n    \"message\": \"Grades imported successfully.\",\n    \"imported_count\": 120\n}"
                        }
                    ]
                }
