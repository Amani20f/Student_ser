{
    "info": {
        "_postman_id": "university-api-final-complete",
        "name": "University Systems - Final Complete Collection",
        "description": "Full collection including Student, Staff, Admin, and Logs logic.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "item": [
        {
            "name": "1. Authentication & Profile",
            "item": [
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Accept",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"email\": \"admin@university.edu\",\n    \"password\": \"password\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/login"
                        }
                    }
                },
                {
                    "name": "Update My Profile",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{authToken}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "PUT",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Ahmed Ali\",\n    \"email\": \"ahmed@student.edu\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/profile/update"
                        }
                    }
                },
                {
                    "name": "Logout",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{authToken}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "url": {
                            "raw": "{{baseUrl}}/logout"
                        }
                    }
                }
            ]
        },
        {
            "name": "2. Student Services",
            "item": [
                {
                    "name": "My Grades",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{authToken}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/student/grades"
                        }
                    }
                },
                {
                    "name": "Submit Payment Receipt",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{authToken}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "semester_id",
                                    "value": "1",
                                    "type": "text"
                                },
                                {
                                    "key": "amount",
                                    "value": "1500",
                                    "type": "text"
                                },
                                {
                                    "key": "receipt_image",
                                    "type": "file",
                                    "src": []
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{baseUrl}}/student/payments"
                        }
                    }
                },
                {
                    "name": "Submit Grievance/Request",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{authToken}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "POST",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"request_type_id\": 1,\n    \"description\": \"I want to review my final exam.\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/student/requests"
                        }
                    }
                }
            ]
        },
        {
            "name": "3. Admin & Audit (The Missing Logic)",
            "item": [
                {
                    "name": "Global Activity Logs",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{authToken}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/admin/logs",
                            "description": "Returns a history of who changed what (Old vs New values)."
                        }
                    }
                },
                {
                    "name": "System Dashboard Stats",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{authToken}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/admin/stats",
                            "description": "Quick count of pending payments, total students, etc."
                        }
                    }
                }
            ]
        },
        {
            "name": "4. Staff Operations",
            "item": [
                {
                    "name": "Approve Payment",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{authToken}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "PUT",
                        "url": {
                            "raw": "{{baseUrl}}/staff/payments/1/verify"
                        }
                    }
                },
                {
                    "name": "Update Student Grade",
                    "request": {
                        "auth": {
                            "type": "bearer",
                            "bearer": [
                                {
                                    "key": "token",
                                    "value": "{{authToken}}",
                                    "type": "string"
                                }
                            ]
                        },
                        "method": "PUT",
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"final\": 45\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{baseUrl}}/staff/grades/1"
                        }
                    }
                }
            ]
        }
    ],
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:8000/api"
        },
        {
            "key": "authToken",
            "value": "PASTE_TOKEN_HERE"
        }
    ]
}